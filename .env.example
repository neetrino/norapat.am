# Marco — environment variables (copy to .env and fill)
# Փաստաթղթ. docs/TECH_CARD.md, docs/02-PROJECT_SPEC.md

# Local dev server (`pnpm dev` uses next dev -p 8989; PORT is for reference / other tools)
PORT=8989

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""

# ——— Auth (NextAuth.js — used in this repo) ———
# Local: http://localhost:8989 | Cloudflare Quick Tunnel: https://YOUR.trycloudflare.com
NEXTAUTH_URL="http://localhost:8989"
# openssl rand -base64 32
NEXTAUTH_SECRET=""
# Optional alias for secret (see middleware / auth.ts)
# AUTH_SECRET=""

# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""

# ——— Payments (Armenian bank / cash) ———

# Idram (wallet, AMD) — callback base URL for wc-api routes
# Local dev without merchant keys (NODE_ENV=development only; never real payments)
# IDRAM_USE_DEV_STUB=true
# Optional override for stub checksums: IDRAM_DEV_STUB_SECRET=""
# IDRAM_TEST_MODE=true
# Test: IDRAM_REC_ACCOUNT + IDRAM_SECRET_KEY (or aliases IDRAM_TEST_REC_ACCOUNT + IDRAM_TEST_SECRET_KEY)
# IDRAM_REC_ACCOUNT=""
# IDRAM_SECRET_KEY=""
# IDRAM_TEST_REC_ACCOUNT=""
# IDRAM_TEST_SECRET_KEY=""
# IDRAM_LIVE_REC_ACCOUNT=""
# IDRAM_LIVE_SECRET_KEY=""
# APP_URL="https://yoursite.com"
# NEXT_PUBLIC_APP_URL="http://localhost:8989"

# Arca (Armenian Card — ArCa/Visa/Mastercard vPOS)
# Test server: https://ipaytest.arca.am:8445/payment/rest/
# Live server: https://ipay.arca.am/payment/rest/
# Credentials provided by your acquiring bank (Armenian Card partner bank).
# ARCA_TEST_MODE=true      — force test server (default if only test keys set)
# ARCA_TEST_MODE=false     — force live server
# ARCA_USE_DEV_STUB=true   — local dev only, skips real registration; NODE_ENV=development required
# ARCA_USE_DEV_STUB=true
# ARCA_TEST_MODE=true
# ARCA_TEST_USERNAME=""
# ARCA_TEST_PASSWORD=""
# ARCA_LIVE_USERNAME=""
# ARCA_LIVE_PASSWORD=""
# APP_URL is also used for Arca returnUrl callbacks (same as Idram)

# ——— Optional ———
# SENTRY_DSN=""
# Google Maps / Mapbox for Contact page
# MAPBOX_PUBLIC_KEY=""
