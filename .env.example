# Local dev server (`pnpm dev` uses next dev -p 8989; PORT is for reference / other tools)
PORT=8989

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""

# ——— Auth (NextAuth.js — used in this repo) ———
# Local: http://localhost:8989 | Cloudflare Quick Tunnel: https://YOUR.trycloudflare.com
NEXTAUTH_URL="http://localhost:8989"
# openssl rand -base64 32
NEXTAUTH_SECRET=""
# Optional alias for secret (see middleware / auth.ts)
# AUTH_SECRET=""

# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Idram credentials for testing and production
IDRAM_TEST_MODE="true"
IDRAM_REC_ACCOUNT=""
IDRAM_SECRET_KEY=""
IDRAM_LIVE_REC_ACCOUNT=""
IDRAM_LIVE_SECRET_KEY=""

# Arca (ArCa / Armenian Card) — REST API merchant credentials (Merchant Manual §7: userName, password)
# Test API:  https://ipaytest.arca.am:8445/payment/rest/
# Live API:  https://ipay.arca.am/payment/rest/
# returnUrl for register.do must be publicly reachable — set APP_URL or NEXT_PUBLIC_APP_URL (e.g. same origin as NEXTAUTH_URL).
ARCA_TEST_MODE="true"
# Test environment: merchant API login and password issued for ipaytest (maps to request param userName)
ARCA_TEST_USERNAME=""
# Test environment: merchant API password (maps to request param password)
ARCA_TEST_PASSWORD=""
# Production: merchant API login (userName) for ipay.arca.am
ARCA_LIVE_USERNAME=""
# Production: merchant API password for ipay.arca.am
ARCA_LIVE_PASSWORD=""
# Development only (NODE_ENV=development): placeholder userName/password so the app starts without test keys (Arca register.do will reject them until real test credentials are set)
ARCA_USE_DEV_STUB="false"