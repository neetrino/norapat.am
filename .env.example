# Local dev server port (`pnpm dev` uses 8989; override with `next dev -p …`). Keep PORT in .env.local if tools need it.
PORT=8989

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""

# ——— Auth (NextAuth.js — used in this repo) ———
# Local: http://localhost:8989 (or match PORT) | Cloudflare Quick Tunnel: https://YOUR.trycloudflare.com
NEXTAUTH_URL="http://localhost:8989"
# openssl rand -base64 32
NEXTAUTH_SECRET=""

# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ——— Idram ———
# In Idram merchant panel register (HTTPS, public): RESULT_URL, SUCCESS_URL, FAIL_URL using APP_URL:
#   {APP_URL}/api/idram_result | {APP_URL}/api/idram_complete | {APP_URL}/api/idram_fail
IDRAM_TEST_MODE="true"
IDRAM_REC_ACCOUNT=""
IDRAM_SECRET_KEY=""
IDRAM_LIVE_REC_ACCOUNT=""
IDRAM_LIVE_SECRET_KEY=""

# ——— Arca (ArCa) — REST merchant API (Manual §7: userName, password) ———
# Test: https://ipaytest.arca.am:8445/payment/rest/ | Live: https://ipay.arca.am/payment/rest/
# returnUrl = {APP_URL or NEXT_PUBLIC_APP_URL}/api/payments/arca/return — register this path with the bank (HTTPS, public).
# Production checklist: set ARCA_TEST_MODE=false; use ARCA_LIVE_*; APP_URL=https://your-production-domain; bank whitelist; test 3DS + settlement.
ARCA_TEST_MODE="true"
ARCA_TEST_USERNAME=""
ARCA_TEST_PASSWORD=""
ARCA_LIVE_USERNAME=""
ARCA_LIVE_PASSWORD=""
